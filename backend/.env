# ═══════════════════════════════════════════════════════════
# REFIND BACKEND — Paste your keys and run
# ═══════════════════════════════════════════════════════════

# ──── DigitalOcean Inference (REQUIRED for real LLM) ──────
# Get from: https://cloud.digitalocean.com → AI/ML → API Keys
# Without this, backend runs in MOCK MODE (fake but realistic data)
DO_INFERENCE_API_KEY=
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1/
MODEL_NAME=meta-llama/Meta-Llama-3.3-70B-Instruct

# ──── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000
