# ──── LLM Providers (priority: OPENAI → DO_INFERENCE) ────────────
OPENAI_API_KEY=your_openai_key_here
GOOGLE_AI_API_KEY=your_google_ai_key_here
GEMINI_MODEL=gemini-2.5-flash

# DigitalOcean Inference (fallback OpenAI-compatible endpoint)
DO_INFERENCE_API_KEY=your_do_inference_key_here
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1/
MODEL_NAME=gpt-4o-mini

# ──── eBay Browse API (get from developer.ebay.com) ──────────────
EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here
EBAY_MARKETPLACE=EBAY_US

# ──── SerpAPI — https://serpapi.com (fair value research) ────────
SERPAPI_KEY=your_serpapi_key_here

# ──── NopeCHA CAPTCHA solver (get from nopecha.com) ──────────────
NOPECHA_API_KEY=your_nopecha_key_here
NOPECHA_EXTENSION_PATH=

# ──── Facebook Marketplace session (run setup_fb_session.py first)
FB_SESSION_PATH=backend/fb_session.json

# ──── Browser settings (Playwright persistent context) ───────────
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=50
MAX_BROWSER_TABS=4

# ──── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000
