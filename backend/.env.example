# ──── LLM Providers (priority: OPENAI → DO_INFERENCE) ────────────
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DigitalOcean Inference (fallback OpenAI-compatible endpoint)
DO_INFERENCE_API_KEY=
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1/
MODEL_NAME=gpt-4o-mini

# ──── eBay Browse API ────────────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_US

# ──── SerpAPI — https://serpapi.com (fair value) ─────────────────
SERPAPI_KEY=

# ──── Browser & Extension (Playwright persistent context) ────────
NOPECHA_API_KEY=
NOPECHA_EXTENSION_PATH=
FB_SESSION_PATH=
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=50
MAX_BROWSER_TABS=4

# ──── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=http://localhost:3000
